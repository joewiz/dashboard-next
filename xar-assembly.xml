<?xml version="1.0" encoding="UTF-8"?>
<package xmlns="http://expath.org/ns/pkg"
         name="${package-name}"
         abbrev="${package-abbrev}"
         version="${project.version}"
         spec="1.0">
    <title>${project.name}</title>
    <description>${project.description}</description>
    <author id="exist-db">${project.organization.name}</author>
    <website>${project.url}</website>
    <license>GNU Lesser General Public License, version 2.1</license>
    <copyright>true</copyright>

    <type>application</type>

    <status>beta</status>

    <tag>dashboard</tag>
    <tag>admin</tag>
    <tag>monitoring</tag>
    <category id="apps">Applications</category>

    <dependency processor="http://exist-db.org" semver-min="7.0.0"/>
    <dependency package="http://e-editiones.org/xquery/templates" semver-min="1.0.0"/>
    <dependency package="http://exist-db.org/html-templating" semver-min="1.0.0"/>

    <target>${package-abbrev}</target>

    <fileSets>
        <fileSet>
            <directory>${basedir}</directory>
            <includes>
                <include>README.md</include>
                <include>LICENSE</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${basedir}/content</directory>
            <outputDirectory>content</outputDirectory>
        </fileSet>
    </fileSets>

    <changelog>
        <change xmlns="http://exist-db.org/xquery/repo" version="3.0.0-SNAPSHOT">
            <ul xmlns="http://www.w3.org/1999/xhtml">
                <li>Ground-up rewrite with Jinks templates and site-shell integration</li>
                <li>Absorbs monitoring features from monex</li>
                <li>Uses exist-api as REST backend</li>
            </ul>
        </change>
    </changelog>
</package>
